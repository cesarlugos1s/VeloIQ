DATABASE_URL=sqlite:///./app.db

# JWT secret — change this to a long random string before deploying to production.
AUTH_SECRET=change-me-to-a-random-64-char-string

# Token expiration in minutes (default: 480 = 8 hours).
# AUTH_TOKEN_EXPIRE_MINUTES=480

# Set to 1 to disable authentication entirely (development only).
# SAFEM_AUTH_DISABLED=1

# Override the default admin seed credentials (used only on first startup).
# SAFEM_ADMIN_USERNAME=admin
# SAFEM_ADMIN_PASSWORD=admin

# SAFEM_ECHO_SQL=1
