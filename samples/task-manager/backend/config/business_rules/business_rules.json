{
    "schema_version": "1.0",
    "rules": [
        {
            "rule_id": "RULE-001",
            "name": "Order Total Calculation",
            "target_model": "Order",
            "type": "formula",
            "definition": {
                "output_field": "total_amount",
                "expression": "sum(items.price * items.quantity)",
                "persist": false
            }
        },
        {
            "rule_id": "RULE-002",
            "name": "High-Value Customer Upgrade",
            "target_model": "Order",
            "type": "inference",
            "when": "on_save",
            "condition": "total_amount >= 5000 and user.tier != 'VIP'",
            "action": {
                "type": "update_property",
                "target": "user.tier",
                "value": "VIP"
            }
        },
        {
            "rule_id": "RULE-003",
            "name": "VIP Shipping Benefit",
            "target_model": "Order",
            "type": "inference",
            "when": "on_save",
            "condition": "user.tier == 'VIP' and shipping_cost > 0",
            "action": {
                "type": "update_property",
                "target": "shipping_cost",
                "value": 0
            }
        },
        {
            "rule_id": "RULE-004",
            "name": "Issue VIP Welcome Loyalty Points",
            "target_model": "Order",
            "type": "inference",
            "when": "on_save",
            "condition": "user.tier == 'VIP'",
            "action": {
                "type": "create_object",
                "model": "RewardPoints",
                "properties": {
                    "user": "user",
                    "points_amount": 500,
                    "reason": "VIP Welcome Bonus"
                }
            }
        },
        {
            "rule_id": "RULE-005",
            "name": "Order Within Credit Limit",
            "target_model": "Order",
            "type": "constraint",
            "when": "on_save",
            "condition": "total_amount <= user.credit_limit",
            "severity": "error",
            "violation": {
                "message": "Order total exceeds the customer's credit limit."
            }
        },
