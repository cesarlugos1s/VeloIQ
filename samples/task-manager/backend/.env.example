# Option A — use the bundled pre-filled SQLite database (no setup required):
DATABASE_URL=sqlite:///./taskmanager.db

# Option B — use your own PostgreSQL instance:
# DATABASE_URL=postgresql://user:password@localhost/taskmanager

# JWT secret — change this before deploying to production.
AUTH_SECRET=task-manager-dev-secret-change-this

# Optional overrides:
# AUTH_TOKEN_EXPIRE_MINUTES=480
# SAFEM_AUTH_DISABLED=1
# SAFEM_MODULES_DIR=app/modules
# CORS_ORIGINS=http://localhost:5173
